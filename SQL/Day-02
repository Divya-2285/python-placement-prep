create database yoo;
use yoo;

CREATE TABLE employee (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(50),
    department VARCHAR(30),
    city VARCHAR(30),
    age INT,
    salary INT,
    experience INT,
    performance_score INT
);

